{
  "expo": {
    "name": "lent-it",
    "slug": "lent-it",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lent-it-schema",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.lentit",
      "associatedDomains": ["applinks:lent-it.yourcompany.com"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.yourcompany.lentit",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "lent-it-schema"
            },
            {
              "scheme": "https",
              "host": "*.supabase.co",
              "pathPrefix": "/auth/v1/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff",
          "enableFullScreenImage_legacy": true
        }
      ],
      [
        "expo-font",
        {
         "fonts": [
           "./assets/fonts/Rubic-Bold.ttf",
           "./assets/fonts/Rubic-ExtraBold.ttf",
           "./assets/fonts/Rubic-Medium.ttf",
           "./assets/fonts/Rubic-Light.ttf",
           "./assets/fonts/Rubic-Regular.ttf",
           "./assets/fonts/Rubic-SemiBold.ttf"
           ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}